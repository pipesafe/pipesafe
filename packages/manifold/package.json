{
  "name": "@pipesafe/manifold",
  "version": "0.6.0",
  "description": "PipeSafe Manifold - DAG composition and orchestration layer for @pipesafe/core",
  "author": "Ryan Peggs & Tim Vyas",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pipesafe/pipesafe.git",
    "directory": "packages/manifold"
  },
  "keywords": [
    "mongodb",
    "dag",
    "orchestration",
    "data-pipeline",
    "etl",
    "pipesafe",
    "materialization"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pipesafe/core": ">=0.5.0 <1.0.0",
    "mongodb": "^6.17.0"
  },
  "devDependencies": {
    "@pipesafe/core": "workspace:*",
    "typescript": "^5.9.3"
  }
}
