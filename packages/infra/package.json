{
  "name": "@pipesafe/infra",
  "version": "0.1.0",
  "description": "PipeSafe Infra - shared cloud infrastructure engine (Pulumi with MongoDB-backed state) for the PipeSafe suite",
  "author": "Ryan Peggs & Tim Vyas",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pipesafe/pipesafe.git",
    "directory": "packages/infra"
  },
  "keywords": [
    "mongodb",
    "pulumi",
    "infrastructure",
    "iac",
    "serverless",
    "pipesafe"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pipesafe/core": ">=2.0.0 <3.0.0",
    "mongodb": "^6.17.0"
  },
  "devDependencies": {
    "@pipesafe/core": "workspace:*",
    "typescript": "^5.9.3"
  }
}
