{
  "name": "@pipesafe/intake",
  "version": "0.1.0",
  "description": "PipeSafe Intake - declarative webhook and REST ingestion into MongoDB, deployed to your cloud via @pipesafe/infra",
  "author": "Ryan Peggs & Tim Vyas",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pipesafe/pipesafe.git",
    "directory": "packages/intake"
  },
  "keywords": [
    "mongodb",
    "ingestion",
    "webhook",
    "change-streams",
    "serverless",
    "etl",
    "pipesafe"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pipesafe/core": ">=1.1.0 <2.0.0",
    "@pipesafe/infra": ">=0.1.0 <1.0.0",
    "mongodb": "^6.17.0"
  },
  "devDependencies": {
    "@pipesafe/core": "workspace:*",
    "@pipesafe/infra": "workspace:*",
    "typescript": "^5.9.3"
  }
}
