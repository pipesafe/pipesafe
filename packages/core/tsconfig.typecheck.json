// Type-gate config: the build tsconfig excludes *.test.ts so tests never
// land in dist, but the typecheck script must still cover them (CI's
// budget:check catching test-only type errors was an accident, not a gate).
{
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false
  }
}
